---
import Container from "./Container.astro";
import { Icon } from "astro-icon/components";
import site from "../data/site.json";

let educations = [
	{
		title: "Bachelor's in Economics",
		school: "Bilkent University",
		date: "September 2022 – May 2026",
		description: "Focusing on Econometrics, Macro-Finance, and Empirical Research.",
	},
	{
		title: "Bachelor's in Applied Economics (Exchange)",
		school: "University of Mannheim",
		date: "August 2025 – January 2026",
		description: "Exchange semester studying Applied Economics.",
	},
	{
		title: "A' Levels",
		school: "Sceptre College",
		date: "August 2019 – May 2021",
		description: "",
	},
	{
		title: "O' Levels",
		school: "Aisha Bawany Academy",
		date: "",
		description: "",
	},
];

let experience = [
	{
		title: "Research Assistant",
		company: "Bilkent University",
		date: "June 2025 – Present",
		description:
			"Estimating aggregate agricultural production functions for Pakistan using national-level time-series data (1961–2022) on cereal production, land, labor, capital, and chemical inputs.",
	},
	{
		title: "Teaching Assistant",
		company: "Bilkent University",
		date: "January 2025 – June 2025",
		description:
			"TA for Intermediate Macroeconomics (ECON 205). Held weekly discussion sections, office hours, and graded assessments and exams.",
	},
	{
		title: "ALM, F/X Trading & Overseas Treasuries Intern",
		company: "Bank Alfalah Limited",
		date: "June 2024 – August 2024",
		description: "Internship in the treasury division covering Asset-Liability Management, foreign exchange trading, and overseas treasury operations.",
	},
	{
		title: "Innovation and Financial Inclusion",
		company: "HBL – Habib Bank Limited",
		date: "August 2023 – July 2024",
		description: "Worked in the Innovation and Financial Inclusion division, contributing to initiatives expanding access to financial services.",
	},
];
---

<div @keydown.escape="aboutOpen=false" class="about fixed left-1/2 -translate-x-1/2 z-20" transition:animate="initial">
	<div class="flex items-center justify-center px-10 py-4 w-full">
		<!-- Left Content -->

		<template x-teleport="body">
			<div
				x-show="aboutOpen"
				x-transition:enter="transition ease-out duration-300"
				x-transition:enter-start="-translate-y-full opacity-0"
				x-transition:enter-end="translate-y-0 opacity-100"
				x-transition:leave="transition ease-in duration-200"
				x-transition:leave-start="translate-y-0 opacity-100"
				x-transition:leave-end="-translate-y-full opacity-0"
				class="flex flex-col gap-32 pt-32 pb-40 fixed inset-0 min-h-screen bg-secondary-50 text-gray-900 overflow-auto">
				<section class="pt-8">
					<Container>
						<div class="flex flex-col self-stretch justify-center about-hero-item">
							<h2 class="text-3xl font-bold pb-4">Haziq Nadeem</h2>
							<p class="text-lg leading-relaxed text-gray-700">
								Economics student at Bilkent University with a focus on Econometrics, Macro-Finance, and Empirical Research.
								Experienced in financial sector internships at Bank Alfalah and HBL, and academic research estimating agricultural
								production functions for Pakistan. Passionate about teaching and quantitative methods.
							</p>
							<div class="flex pt-8 gap-6">
								{
									site.socials.map((social) => (
										<a
											data-cursor-hover
											data-hover-title
											aria-label="Social"
											href={social.link}
											target="_blank"
											rel="noopener noreferrer"
											class="text-gray-600 hover:text-gray-900 transition-colors duration-200">
											<Icon class="w-5 h-5" name={social.icon} />
										</a>
									))
								}
							</div>
						</div>
					</Container>
				</section>

				<section>
					<Container class="flex flex-col gap-16 justify-between">
						<div class="flex flex-col">
							<p class="text-xs uppercase tracking-widest text-gray-400 mb-2">Work</p>
							<h2 class="text-2xl font-bold mb-8">Experience</h2>
							<div class="grid lg:grid-cols-2 gap-6">
								{
									experience.map((e) => (
										<div class="experience-item card-hover border border-gray-200 rounded-xl p-6 border-l-4" style="border-left-color: #00F5D4;">
											<div class="flex flex-wrap items-center gap-3 mb-3">
												<h3 class="text-lg font-semibold">{e.title}</h3>
												{e.date && (
													<span class="text-xs bg-gray-100 rounded-full px-3 py-1 text-gray-500 whitespace-nowrap">{e.date}</span>
												)}
											</div>
											<h5 class="font-semibold text-sm text-gray-600 mb-3">{e.company}</h5>
											{e.description && <p class="text-sm leading-relaxed text-gray-600">{e.description}</p>}
										</div>
									))
								}
							</div>
						</div>
						<div class="flex flex-col">
							<p class="text-xs uppercase tracking-widest text-gray-400 mb-2">Academic</p>
							<h2 class="text-2xl font-bold mb-8">Education</h2>
							<div class="grid lg:grid-cols-2 gap-6">
								{
									educations.map((e) => (
										<div class="education-item card-hover border border-gray-200 rounded-xl p-6 border-l-4" style="border-left-color: #00F5D4;">
											<div class="flex flex-wrap items-center gap-3 mb-3">
												<h3 class="text-lg font-semibold">{e.title}</h3>
												{e.date && (
													<span class="text-xs bg-gray-100 rounded-full px-3 py-1 text-gray-500 whitespace-nowrap">{e.date}</span>
												)}
											</div>
											<h5 class="font-semibold text-sm text-gray-600 mb-3">{e.school}</h5>
											{e.description && <p class="text-sm leading-relaxed text-gray-600">{e.description}</p>}
										</div>
									))
								}
							</div>
						</div>
					</Container>
				</section>
			</div>
		</template>

		<div
			x-show="!portfolioOpen"
			@click="aboutOpen = !aboutOpen; if (aboutOpen) { $nextTick(() => window.animateAboutIn && window.animateAboutIn()) }"
			class="p-4 select-none text-center cursor-pointer cursor-target"
			data-cursor-hover
			data-cursor-parallax>
			<span
				class="cursor-target-text block break-keep whitespace-nowrap"
				data-cursor-parallax-elelement
				x-text="aboutOpen ? 'Close' : 'About Me'">
			</span>
		</div>
	</div>
</div>

<script>
	import { gsap } from "gsap";

	document.addEventListener("astro:page-load", () => {
		window.animateAboutIn = () => {
			gsap.fromTo(
				".about-hero-item, .experience-item, .education-item",
				{ opacity: 0, y: 24 },
				{ opacity: 1, y: 0, duration: 0.35, stagger: 0.07, ease: "power2.out", clearProps: "all" }
			);
		};
	});
</script>

<style>
	.about {
		mix-blend-mode: difference;
		position: fixed;
		top: 0;
	}
</style>
