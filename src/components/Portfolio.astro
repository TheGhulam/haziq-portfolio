---
import { Icon } from "astro-icon/components";
import Container from "./Container.astro";
import { getCollection } from "astro:content";

const portfolioEntries = await getCollection("portfolio");
---

<div @keydown.escape="portfolioOpen=false" class="portfolio w-full fixed z-20" transition:animate="initial">
	<div class="flex justify-center px-10 pt-50 py-4 w-full items-center">
		<template x-teleport="body">
			<div
				x-show="portfolioOpen"
				x-transition:enter="transition ease-out duration-300"
				x-transition:enter-start="translate-y-full opacity-0"
				x-transition:enter-end="-translate-y-0 opacity-100"
				x-transition:leave="transition ease-in duration-200"
				x-transition:leave-start="translate-y-0 opacity-100"
				x-transition:leave-end="translate-y-full opacity-0"
				class="flex flex-col fixed inset-0 w-screen pt-32 pb-52 bg-secondary-50 overflow-auto">
				<section class="pt-8">
					<Container>
						<p class="text-xs uppercase tracking-widest text-gray-400 mb-2">Selected work</p>
						<h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">My recent work</h2>
						<p class="mt-2 text-lg leading-relaxed text-gray-600">Here you can see my latest projects</p>
						<div class="flex flex-col mt-12 lg:mt-16 gap-8">
							{
								portfolioEntries.map((entry) => (
									<article class="portfolio-item card-hover relative isolate flex flex-col gap-8 lg:flex-row lg:odd:flex-row-reverse bg-white/60 backdrop-blur-sm rounded-2xl p-8 border border-gray-100">
										<div class="portfolio-img-wrap relative aspect-video lg:w-[28rem] lg:shrink-0">
											<img
												src={entry.data.image.src}
												alt={entry.data.image.alt}
												class="absolute inset-0 h-full w-full bg-gray-50 object-cover"
											/>
										</div>
										<div class="flex flex-col justify-center">
											<div class="flex items-center gap-3 mb-3">
												<span class="text-xs bg-gray-100 rounded-full px-3 py-1 text-gray-500">
													{entry.data.publishDate.toLocaleDateString("en-US", { year: "numeric" })}
												</span>
											</div>
											<div class="group relative max-w-xl">
												<h3 class="text-2xl font-bold leading-tight text-gray-900 group-hover:text-gray-600 transition-colors duration-200">
													{entry.data.title}
												</h3>
												<p class="mt-4 pb-6 text-sm leading-relaxed text-gray-600">{entry.data.snippet}</p>
												<div class="flex gap-4 text-gray-700">
													{entry.data.links.map((link) => (
														<a
															data-cursor-hover
															data-hover-title
															aria-label="Social"
															href={link.src}
															target="_blank"
															rel="noopener noreferrer"
															class="hover:text-gray-900 transition-colors duration-200">
															<Icon class="w-5 h-5" name={link.icon} />
														</a>
													))}
												</div>
											</div>
										</div>
									</article>
								))
							}
						</div>
					</Container>
				</section>
			</div>
		</template>

		<div
			x-show="!aboutOpen"
			@click="portfolioOpen = !portfolioOpen; if (portfolioOpen) { $nextTick(() => window.animatePortfolioIn && window.animatePortfolioIn()) }"
			class="p-4 select-none cursor-pointer cursor-target text-center text-gray-900 hover:text-gray-600 transition-colors text-2xl font-semibold tracking-wide"
			data-cursor-hover
			data-cursor-parallax>
			<span class="cursor-target-text block break-keep" data-cursor-parallax-elelement x-text="portfolioOpen ? 'Close' : 'Portfolio'"></span>
		</div>
	</div>
</div>
<!--END Header -->

<script>
	import { gsap } from "gsap";

	document.addEventListener("astro:page-load", () => {
		window.animatePortfolioIn = () => {
			gsap.fromTo(
				".portfolio-item",
				{ opacity: 0, y: 32 },
				{ opacity: 1, y: 0, duration: 0.4, stagger: 0.08, ease: "power2.out", clearProps: "all" }
			);
		};
	});
</script>

<style>
	.portfolio {
		position: fixed;
		bottom: 0;
	}
</style>
