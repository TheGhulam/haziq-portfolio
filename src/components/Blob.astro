---
---

<div class="content w-full">
	<canvas class="scene scene--full" id="scene"></canvas>
	<div class="content__inner">
		<img
			src="/images/header.png"
			alt="Haziq Nadeem"
			class="hero-avatar"
		/>
		<img
			height="200"
			width="600"
			class="lg:max-w-lg"
			src="/images/hero-text.png"
			alt="Haziq Nadeem"
			style="filter: hue-rotate(80deg) saturate(1.8) brightness(0.45);"
		/>
	</div>
</div>

<script>
	document.addEventListener("astro:page-load", () => {
		const canvas = document.querySelector<HTMLCanvasElement>("#scene");
		if (!canvas) return;
		const ctx = canvas.getContext("2d")!;

		const COLORS = ["#00c4aa", "#3533cd", "#333333"];
		const TYPES = ["circle", "square", "triangle"] as const;
		const SHAPE_SIZE = 80;
		const COUNT = 10;
		const REPEL_RADIUS = 130;
		const REPEL_FORCE = 4.5;
		const SPEED_MIN = 0.6;
		const SPEED_MAX = 1.8;

		type ShapeType = (typeof TYPES)[number];

		interface Shape {
			x: number;
			y: number;
			vx: number;
			vy: number;
			angle: number;
			spin: number;
			size: number;
			type: ShapeType;
			color: string;
			alpha: number;
		}

		let W = 0, H = 0;
		const mouse = { x: -9999, y: -9999 };
		let shapes: Shape[] = [];
		let rafId: number;

		function rand(min: number, max: number) {
			return Math.random() * (max - min) + min;
		}

		function makeShape(w: number, h: number): Shape {
			const size = SHAPE_SIZE;
			const speed = rand(SPEED_MIN, SPEED_MAX);
			const angle2d = rand(0, Math.PI * 2);
			return {
				x: rand(size, w - size),
				y: rand(size, h - size),
				vx: Math.cos(angle2d) * speed,
				vy: Math.sin(angle2d) * speed,
				angle: rand(0, Math.PI * 2),
				spin: rand(-0.018, 0.018),
				size,
				type: TYPES[Math.floor(Math.random() * TYPES.length)],
				color: COLORS[Math.floor(Math.random() * COLORS.length)],
				alpha: rand(0.45, 0.85),
			};
		}

		function resize() {
			W = canvas.offsetWidth;
			H = canvas.offsetHeight;
			canvas.width = W * devicePixelRatio;
			canvas.height = H * devicePixelRatio;
			ctx.scale(devicePixelRatio, devicePixelRatio);
		}

		function init() {
			resize();
			shapes = Array.from({ length: COUNT }, () => makeShape(W, H));
		}

		function drawCircle(s: Shape) {
			ctx.beginPath();
			ctx.arc(0, 0, s.size / 2, 0, Math.PI * 2);
			ctx.stroke();
		}

		function drawSquare(s: Shape) {
			const h = s.size / 2;
			ctx.beginPath();
			ctx.rect(-h, -h, s.size, s.size);
			ctx.stroke();
		}

		function drawTriangle(s: Shape) {
			const r = s.size / 2;
			ctx.beginPath();
			ctx.moveTo(0, -r);
			ctx.lineTo(r * 0.866, r * 0.5);
			ctx.lineTo(-r * 0.866, r * 0.5);
			ctx.closePath();
			ctx.stroke();
		}

		function draw(s: Shape) {
			ctx.save();
			ctx.translate(s.x, s.y);
			ctx.rotate(s.angle);
			ctx.globalAlpha = s.alpha;
			ctx.strokeStyle = s.color;
			ctx.lineWidth = 2;
			if (s.type === "circle") drawCircle(s);
			else if (s.type === "square") drawSquare(s);
			else drawTriangle(s);
			ctx.restore();
		}

		function update() {
			for (let i = 0; i < shapes.length; i++) {
				const s = shapes[i];

				// Mouse repulsion
				const dx = s.x - mouse.x;
				const dy = s.y - mouse.y;
				const dist = Math.sqrt(dx * dx + dy * dy);
				if (dist < REPEL_RADIUS && dist > 0) {
					const force = (REPEL_RADIUS - dist) / REPEL_RADIUS * REPEL_FORCE;
					s.vx += (dx / dist) * force;
					s.vy += (dy / dist) * force;
				}

				// Speed cap
				const speed = Math.sqrt(s.vx * s.vx + s.vy * s.vy);
				if (speed > 6) {
					s.vx = (s.vx / speed) * 6;
					s.vy = (s.vy / speed) * 6;
				}

				// Gentle return to natural speed
				if (speed > SPEED_MAX) {
					s.vx *= 0.985;
					s.vy *= 0.985;
				}

				s.x += s.vx;
				s.y += s.vy;
				s.angle += s.spin;

				const r = s.size / 2;
				if (s.x - r < 0) { s.x = r; s.vx = Math.abs(s.vx); }
				if (s.x + r > W) { s.x = W - r; s.vx = -Math.abs(s.vx); }
				if (s.y - r < 0) { s.y = r; s.vy = Math.abs(s.vy); }
				if (s.y + r > H) { s.y = H - r; s.vy = -Math.abs(s.vy); }

				// Shape-to-shape collision (circle approximation)
				for (let j = i + 1; j < shapes.length; j++) {
					const b = shapes[j];
					const cdx = b.x - s.x;
					const cdy = b.y - s.y;
					const minDist = (s.size + b.size) / 2;
					const d = Math.sqrt(cdx * cdx + cdy * cdy);
					if (d < minDist && d > 0) {
						const nx = cdx / d;
						const ny = cdy / d;
						const relV = (s.vx - b.vx) * nx + (s.vy - b.vy) * ny;
						if (relV > 0) {
							s.vx -= relV * nx;
							s.vy -= relV * ny;
							b.vx += relV * nx;
							b.vy += relV * ny;
						}
						// Separate overlapping shapes
						const overlap = minDist - d;
						s.x -= nx * overlap * 0.5;
						s.y -= ny * overlap * 0.5;
						b.x += nx * overlap * 0.5;
						b.y += ny * overlap * 0.5;
					}
				}
			}
		}

		function loop() {
			ctx.clearRect(0, 0, W, H);
			update();
			shapes.forEach(draw);
			rafId = requestAnimationFrame(loop);
		}

		function onMouseMove(e: MouseEvent) {
			const rect = canvas.getBoundingClientRect();
			mouse.x = e.clientX - rect.left;
			mouse.y = e.clientY - rect.top;
		}

		function onResize() {
			cancelAnimationFrame(rafId);
			// Save current velocities/types, re-init positions for new size
			const prev = shapes.map(s => ({ type: s.type, color: s.color, size: s.size, vx: s.vx, vy: s.vy, spin: s.spin }));
			resize();
			shapes = prev.map(p => ({
				...makeShape(W, H),
				type: p.type,
				color: p.color,
				size: p.size,
				vx: p.vx,
				vy: p.vy,
				spin: p.spin,
			}));
			rafId = requestAnimationFrame(loop);
		}

		init();
		rafId = requestAnimationFrame(loop);
		window.addEventListener("mousemove", onMouseMove);
		window.addEventListener("resize", onResize);

		// Cleanup on page transitions
		document.addEventListener("astro:before-swap", () => {
			cancelAnimationFrame(rafId);
			window.removeEventListener("mousemove", onMouseMove);
			window.removeEventListener("resize", onResize);
		}, { once: true });
	});
</script>

<style>
	.content {
		position: relative;
		display: grid;
		justify-content: center;
		align-items: center;
		align-content: center;
		margin: 0 auto;
		min-height: 100vh;
	}

	.content__inner {
		grid-area: 1 / 1 / 1 / 1;
		position: relative;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		align-content: center;
	}

	.scene {
		position: absolute;
	}

	.scene--full {
		width: 100%;
		height: 100vh;
	}

	.hero-avatar {
		width: 220px;
		height: auto;
		margin-bottom: 1rem;
	}

	@media screen and (max-width: 55em) {
		.content {
			flex-direction: column;
			height: auto;
		}
	}
</style>
