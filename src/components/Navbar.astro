---
import { Icon } from "astro-icon/components";
import site from "../data/site.json";
---

<nav class="z-10 w-full pt-6 px-6 absolute top-0 flex justify-between items-start md:items-center">
	<div id="logo" :class="(portfolioOpen || aboutOpen) ? 'popup-open' : ''">
		<a
			data-cursor-hover
			data-hover-title
			aria-label="Home"
			class="block"
			href="/"
			@click="if (portfolioOpen) { portfolioOpen = false } else if (aboutOpen) { aboutOpen = false }">
			<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 88 40" class="h-9 w-auto" aria-hidden="true">
				<!-- radical tick: small descender, then up-stroke, then overline over HOME -->
				<polyline
					points="2,28 8,36 16,4 86,4"
					fill="none"
					stroke="currentColor"
					stroke-width="2.2"
					stroke-linejoin="round"
					stroke-linecap="round"
				/>
				<text x="18" y="30" font-family="Inter, sans-serif" font-size="20" fill="currentColor" letter-spacing="1">HOME</text>
			</svg>
		</a>
	</div>
	<div id="social" x-show="!portfolioOpen && !aboutOpen">
		<div class="flex flex-col md:flex-row gap-6">
			{
				site.socials.map((social) => (
					<a data-cursor-hover data-hover-title aria-label="Social" href={social.link} target="_blank" rel="noopener noreferrer" class="text-gray-700 hover:text-gray-900 transition-colors">
						<Icon class="w-9 h-9" name={social.icon} />
					</a>
				))
			}
		</div>
	</div>
</nav>

<script>
	import { gsap } from "gsap";

	document.addEventListener("astro:page-load", () => {
		const nav = document.querySelector("nav");
		const logo = document.getElementById("logo");
		const socials = document.querySelectorAll("#social a");

		gsap.fromTo(logo, { opacity: 0, y: -12 }, { opacity: 1, y: 0, duration: 0.5, ease: "power2.out" });
		gsap.fromTo(
			socials,
			{ opacity: 0, y: -8 },
			{ opacity: 1, y: 0, duration: 0.4, stagger: 0.04, ease: "power2.out", delay: 0.15 }
		);
	});
</script>

