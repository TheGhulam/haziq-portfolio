---
import { Icon } from "astro-icon/components";
import site from "../data/site.json";
---

<nav class="z-10 w-full pt-6 px-6 absolute top-0 flex justify-between items-start md:items-center">
	<div id="logo" :class="(portfolioOpen || aboutOpen) ? 'popup-open' : ''">
		<a
			data-cursor-hover
			data-hover-title
			aria-label="Home"
			class="block"
			href="/"
			@click="if (portfolioOpen) { portfolioOpen = false } else if (aboutOpen) { aboutOpen = false }">
			<img height="45" width="45" class="w-10" src="/logo.svg" alt="Logo" />
		</a>
	</div>
	<div id="social" x-show="!portfolioOpen && !aboutOpen">
		<div class="flex flex-col md:flex-row gap-6">
			{
				site.socials.map((social) => (
					<a data-cursor-hover data-hover-title aria-label="Social" href={social.link} target="_blank" rel="noopener noreferrer">
						<Icon class="w-4 h-4" name={social.icon} />
					</a>
				))
			}
		</div>
	</div>
</nav>

<script>
	import { gsap } from "gsap";

	document.addEventListener("astro:page-load", () => {
		const nav = document.querySelector("nav");
		const logo = document.getElementById("logo");
		const socials = document.querySelectorAll("#social a");

		gsap.fromTo(logo, { opacity: 0, y: -12 }, { opacity: 1, y: 0, duration: 0.5, ease: "power2.out" });
		gsap.fromTo(
			socials,
			{ opacity: 0, y: -8 },
			{ opacity: 1, y: 0, duration: 0.4, stagger: 0.04, ease: "power2.out", delay: 0.15 }
		);
	});
</script>

<style>
	nav {
		mix-blend-mode: difference;
	}
</style>
